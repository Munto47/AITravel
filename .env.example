# ===== LLM =====
# OpenAI API Key（使用兼容 OpenAI 格式的接口）
OPENAI_API_KEY=sk-your-key-here
# OpenAI API Base URL（如使用第三方中转服务）
OPENAI_API_URL=https://api.openai.com/v1

# ===== 高德地图（两个 Key 用途不同）=====
# 后端 REST API Key（用于 POI 搜索、距离矩阵），在高德控制台创建"Web服务"类型
AMAP_API_KEY=your-amap-rest-api-key

# 前端 JS SDK Key（用于地图展示），配置在 frontend/.env.local，需在控制台添加 localhost:3000 白名单
AMAP_JS_KEY=your-amap-js-key

# true=使用本地 fixture 文件，false=真实调用高德 API（保护配额）
AMAP_MOCK=true

# ===== 和风天气 =====
QWEATHER_KEY=your-qweather-key

# ===== Docker（无法直连 hub.docker.com 时使用镜像加速）=====
# 在 Docker Desktop → Settings → Docker Engine 中配置 registry-mirrors 后，一般无需改下列变量。
# 若构建仍拉取失败，可改为第三方镜像前缀（示例，请换为你当前可用的源）：
# Y_WEBSOCKET_NODE_IMAGE=docker.1ms.run/library/node:18-alpine
# BACKEND_PYTHON_IMAGE=docker.1ms.run/library/python:3.11-alpine
# POSTGRES_IMAGE=docker.1ms.run/pgvector/pgvector:pg16
# REDIS_IMAGE=docker.1ms.run/library/redis:7-alpine

# ===== 数据库（本地开发，docker-compose 自动覆盖此值）=====
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/travel_agent
REDIS_URL=redis://localhost:6379

# ===== Demo 模式 =====
# true=绕过 LLM 调用，返回预设 Demo 数据（面试演示保底方案）
DEMO_MODE=false
