# =============================================================
# AI 智能旅行协同规划系统 — 后端环境变量模板
# cp .env.example .env  然后填写真实值
# =============================================================

# ===== LLM — OpenAI 兼容接口 =====
# 支持 OpenAI 官方 / SiliconFlow / DeepSeek / 其他兼容服务
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_API_URL=https://api.openai.com/v1

# OpenAI 兼容模式下使用的模型名称（SiliconFlow 示例）
# LLM_MODEL_ROUTER=Qwen/Qwen2.5-7B-Instruct
# LLM_MODEL_SYNTHESIZER=Qwen/Qwen2.5-7B-Instruct

# ===== 高德地图（两个 Key 类型不同，不可互换）=====

# 后端 REST API Key — 高德控制台新建"Web服务"类型
AMAP_API_KEY=your-amap-rest-api-key

# true=使用本地 Mock 数据（默认，保护 API 配额）; false=真实调用高德 API
AMAP_MOCK=true

# ===== 和风天气 =====
# 推荐使用 JWT 认证（无 Host 白名单限制，服务端调用安全）
# 步骤：控制台 → 项目管理 → 添加凭据 → 选择 JSON Web Token → 上传公钥
QWEATHER_API_HOST=xxxxxxxx.re.qweatherapi.com  # 控制台「项目管理」→ API Host 字段
QWEATHER_AUTH_TYPE=jwt                  # "jwt"（推荐）或 "apikey"

# JWT 模式必填（凭据 ID 和项目 ID 在控制台-项目管理中查看）
QWEATHER_PRIVATE_KEY=your-ed25519-private-key-base64  # PKCS8 私钥 base64 正文（不含 PEM 头尾）
QWEATHER_KEY_ID=your-credential-id                    # 控制台凭据 ID（kid）
QWEATHER_PROJECT_ID=your-project-id                   # 控制台项目 ID（sub）

# API KEY 模式（降级备用，需控制台设置 Host 为无限制）
# QWEATHER_API_KEY=your-qweather-api-key
# QWEATHER_AUTH_TYPE=apikey

# ===== 数据库（docker-compose 启动时会自动覆盖此值）=====
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/travel_agent
REDIS_URL=redis://localhost:6379

# ----- Railway / 托管 Postgres -----
# 1) pgvector：业务表依赖 CREATE EXTENSION vector。若 Railway 自带 Postgres 未装 pgvector，可改用
#    Neon / Supabase 等支持 pgvector 的实例，将连接串填到 DATABASE_URL。
# 2) SSL：托管库常见在连接串末尾追加 ?sslmode=require（本仓库 asyncpg / LangGraph 已兼容）。
# 3) 空库首次部署：在 backend 目录执行（需已配置 DATABASE_URL）：
#      python scripts/apply_init_sql.py
#    以执行 app/db/init.sql（LangGraph checkpoint 表由应用启动时自动建）。
# 4) Redis：在 Railway 添加 Redis 插件后，将 REDIS_URL 指向插件提供的地址（常为 rediss://）。
# 5) CORS：前端若使用自定义域名，设置 CORS_ORIGIN_REGEX 匹配你的 https 源（默认已含 *.railway.app）。

# ===== Demo 模式 =====
# true=跳过所有 LLM 调用，返回预置数据（无需任何 API Key 即可完整体验）
DEMO_MODE=false

# ===== CORS（生产环境部署时按需修改）=====
# 允许跨域访问的前端 Origin 正则；默认含 localhost 与 *.railway.app
# 自定义域名示例：
# CORS_ORIGIN_REGEX=^https://(your-app\.example\.com|localhost(:\d+)?)$

# ===== Docker 镜像加速（国内网络拉取超时时启用）=====
# Y_WEBSOCKET_NODE_IMAGE=docker.1ms.run/library/node:18-alpine
# BACKEND_PYTHON_IMAGE=docker.1ms.run/library/python:3.11-alpine
# POSTGRES_IMAGE=docker.1ms.run/pgvector/pgvector:pg16
# REDIS_IMAGE=docker.1ms.run/library/redis:7-alpine
