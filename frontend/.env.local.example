# =============================================================
# 前端环境变量模板
# cp frontend/.env.local.example frontend/.env.local
# =============================================================

# 后端 API 地址（本地开发默认值；生产部署时改为实际 URL，如 https://your-backend.railway.app）
NEXT_PUBLIC_API_URL=http://localhost:8000

# Yjs WebSocket 地址（本地开发默认值；生产部署时改为实际 URL，如 wss://your-yws.railway.app）
NEXT_PUBLIC_Y_WEBSOCKET_URL=ws://localhost:1234

# 高德地图 JS SDK Key
# 获取方式：https://console.amap.com → 应用管理 → 新建应用 → 类型选"Web端(JS API)"
# 注意：此 Key 与后端 AMAP_API_KEY（Web服务类型）是两个不同的应用，不可互换
NEXT_PUBLIC_AMAP_JS_KEY=your-amap-js-api-key

# 高德地图安全密钥（控制台 → 应用 → 数字签名）
NEXT_PUBLIC_AMAP_SECURITY_CODE=your-amap-security-code
